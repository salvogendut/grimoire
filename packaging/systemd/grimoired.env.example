# Optional user environment for grimoired.service.
#
# Install as:
#   ~/.config/grimoire/grimoired.env
#
# The systemd user unit reads this file with EnvironmentFile=-, so the service
# still starts when the file is absent.

# Service command-line arguments. Keep --execute-listen here; the GNOME Shell
# top-bar execution gate still starts disarmed and must be armed explicitly.
GRIMOIRE_DAEMON_ARGS="--listen-service --execute-listen --record-seconds 3"

# whisper.cpp binary/model overrides.
# GRIMOIRE_WHISPER_CLI=/usr/bin/whisper-cli
# GRIMOIRE_WHISPER_MODEL=/home/salvogendut/.local/share/grimoire/models/ggml-base.en.bin

# Optional AI interpreter. Default is off unless GRIMOIRE_AI_MODE is set or
# grimoired is launched with --ai/--ai-mode.
# GRIMOIRE_AI_PROVIDER=openai
# GRIMOIRE_AI_MODE=fallback
# GRIMOIRE_OPENAI_MODEL=gpt-4o-mini
# GRIMOIRE_AI_MIN_CONFIDENCE=0.65
# OPENAI_API_KEY=

# Cloud AI endpoints must use HTTPS. Plain HTTP is accepted only for localhost
# or other loopback addresses.
# OPENAI_BASE_URL=https://api.openai.com/v1
