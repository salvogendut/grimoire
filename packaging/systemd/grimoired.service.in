[Unit]
Description=Grimoire voice command daemon
Documentation=https://github.com/salvogendut/grimoire
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
EnvironmentFile=-%h/.config/grimoire/grimoired.env
Environment="GRIMOIRE_DAEMON_ARGS=--listen-service --execute-listen --record-seconds 3"
ExecStart=@BINDIR@/grimoired $GRIMOIRE_DAEMON_ARGS
Restart=on-failure
RestartSec=2

[Install]
WantedBy=default.target
